NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/fitguard
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=7d

# Used to build verification/reset links when provider-specific URLs are not set.
APP_BASE_URL=http://localhost:3000
VERIFY_EMAIL_URL=https://fitguard-api.fly.dev/api/auth/verify-email
RESET_PASSWORD_URL=https://fitguard-api.fly.dev/api/auth/reset-password


